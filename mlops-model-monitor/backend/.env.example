# Prediction log store. SQLite by default; swap for a Postgres DSN with no
# code changes, e.g. postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./monitor.db

# Allowed CORS origin for the dashboard (no trailing slash).
CLIENT_URL=http://localhost:5173

# Drift thresholds.
DRIFT_PSI_THRESHOLD=0.2
DRIFT_PVALUE_THRESHOLD=0.05

# Reference sample size persisted at train time.
REFERENCE_SAMPLE_SIZE=600
